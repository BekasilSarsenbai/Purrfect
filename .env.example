NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/purrfect?schema=public
JWT_ACCESS_SECRET=replace_with_at_least_32_characters_access_secret
JWT_REFRESH_SECRET=replace_with_at_least_32_characters_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PLATFORM_FEE_PERCENT=5
REDIS_URL=redis://redis:6379
