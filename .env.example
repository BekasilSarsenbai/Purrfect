NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/purrfect?schema=public
JWT_ACCESS_SECRET=replace_with_at_least_32_characters_access_secret
JWT_REFRESH_SECRET=replace_with_at_least_32_characters_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PLATFORM_FEE_PERCENT=5
REDIS_URL=redis://redis:6379
ADMIN_EMAIL=admin@purrfect.local
ADMIN_PASSWORD=replace_with_strong_admin_password
ADMIN_DISPLAY_NAME=Platform Admin
# Resend.com — used by the email worker (sign up at https://resend.com → API Keys)
RESEND_API_KEY=re_replace_with_resend_api_key
# Sandbox sender works without domain verification; replace with your verified domain in prod
EMAIL_FROM=Purrfect <onboarding@resend.dev>
APP_BASE_URL=http://localhost:3000
# 'log' = print rendered email to stdout (no Resend call); flip to 'live' in production / for graded demo
EMAIL_DELIVERY_MODE=log
